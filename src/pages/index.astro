---
// Aquí puedes dejar el frontmatter vacío o añadir lógica extra
import "../styles/global.css";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Una invitación especial</title>
  </head>
  <body class="bg-pink-100 flex items-center justify-center h-screen font-sans">
    <div
      id="ventana"
      class="bg-white p-8 rounded-2xl shadow-xl w-96 text-center"
    >
      <h1 class="text-2xl font-bold text-pink-600 mb-6">
        Debido a fuentes de validación de información realizada por Joseluis,
        responde correctamente abajo
      </h1>

      <p class="mb-4 text-gray-700">¿Cuál es mi plato favorito?</p>

      <div id="opciones" class="space-y-3">
        <button
          class="opcion w-full py-2 border-2 border-pink-200 rounded-lg hover:bg-pink-50"
          data-valor="20">Aji de pollo</button
        >
        <button
          class="opcion w-full py-2 border-2 border-pink-200 rounded-lg hover:bg-pink-50"
          data-valor="21">Locro de zapallo</button
        >
        <button
          class="opcion w-full py-2 border-2 border-pink-200 rounded-lg hover:bg-pink-50"
          data-valor="22">Arroz chaufa</button
        >
      </div>

      <p id="mensaje" class="mt-6 font-bold hidden"></p>

      <button
        id="btnReiniciar"
        class="mt-4 hidden w-full py-2 bg-pink-500 text-white rounded-lg hover:bg-pink-600"
      >
        Intentar de nuevo
      </button>
    </div>

    <script>
      const opciones = document.querySelectorAll(".opcion");
      const mensaje = document.getElementById("mensaje");
      const btnReiniciar = document.getElementById("btnReiniciar");

      opciones.forEach((btn) => {
        btn.addEventListener("click", () => {
          const valor = btn.getAttribute("data-valor");

          if (valor === "21") {
            mensaje.textContent =
              "¡Correcto! Chio, eres una genia, me alegra saber que sepas eso de mí.... ❤️";
            mensaje.classList.remove("hidden", "text-red-500");
            mensaje.classList.add("text-green-600");
            opciones.forEach((o) => (o.disabled = true));
            btnReiniciar.classList.add("hidden"); // Ocultamos el botón si ya acertó
          } else {
            mensaje.textContent = "No es correcto... ¡Inténtalo de nuevo! 😉";
            mensaje.classList.remove("hidden", "text-green-600");
            mensaje.classList.add("text-red-500");
            btnReiniciar.classList.remove("hidden"); // Mostramos el botón de reintento
          }
        });
      });

      // Lógica para reiniciar
      btnReiniciar.addEventListener("click", () => {
        mensaje.classList.add("hidden");
        btnReiniciar.classList.add("hidden");
        opciones.forEach((o) => (o.disabled = false));
      });
    </script>
  </body>
</html>
